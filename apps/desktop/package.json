{
  "name": "@my-pet/desktop",
  "private": true,
  "version": "0.2.16",
  "type": "module",
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/clean-desktop-build.ps1 . && next build",
    "start": "next start",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/",
    "clean": "rimraf dist src-tauri/target",
    "tauri": "tauri",
    "tauri:icon": "tauri icon src-tauri/assets/logo.png",
    "tauri:dev": "corepack pnpm tauri:icon && tauri dev",
    "tauri:build": "corepack pnpm tauri:icon && powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/stage-manager-pet-resource.ps1 && tauri build",
    "tauri:build:debug": "corepack pnpm tauri:icon && powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/stage-manager-pet-resource.ps1 && tauri build --debug",
    "build:all": "corepack pnpm clean && corepack pnpm build && corepack pnpm tauri:build",
    "release:prepare": "corepack pnpm lint && corepack pnpm format && corepack pnpm build",
    "release:build": "corepack pnpm release:prepare && corepack pnpm tauri:build",
    "release": "bash ../../scripts/release.sh"
  },
  "dependencies": {
    "@my-pet/shared-config": "workspace:*",
    "@my-pet/shared-prompts": "workspace:*",
    "@my-pet/shared-types": "workspace:*",
    "@base-ui/react": "^1.2.0",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-fs": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.2.7",
    "@tauri-apps/plugin-os": "^2.3.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.576.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.27.0",
    "@next/eslint-plugin-next": "^15.3.2",
    "@tailwindcss/postcss": "^4.1.7",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitejs/plugin-react": "^4.5.1",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.3.2",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "rimraf": "^5.0.10",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
