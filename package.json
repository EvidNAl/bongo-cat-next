{
  "name": "my-pet-assistant",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @my-pet/desktop --filter @my-pet/agent-service run dev",
    "dev:desktop": "pnpm --filter @my-pet/desktop dev",
    "dev:agent": "pnpm --filter @my-pet/agent-service dev",
    "tauri:dev": "pnpm --filter @my-pet/desktop tauri:dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}
